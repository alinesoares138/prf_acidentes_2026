Tratamento de dados

-Tratando o campo tipo_acidente:
SELECT DISTINCT 
	d.tipo_acidente ,
	CASE 
        WHEN tipo_acidente LIKE '%Colis%' OR tipo_acidente LIKE '%Atropelamento%' OR tipo_acidente = 'Engavetamento' THEN 'ACIDENTE'
        WHEN tipo_acidente IN ('Tombamento', 'Capotamento') THEN 'TOMBAMENTO'
        WHEN tipo_acidente IN ('Incêndio', 'Derramamento de carga', 'Queda de ocupante de veículo') OR tipo_acidente LIKE '%objeto%' THEN 'AVARIA'
        WHEN tipo_acidente LIKE '%Roubo%' THEN 'ROUBO' -- Caso adicione dados externos futuramente
        ELSE 'OUTROS'
    END  as agrupamento
FROM
	datatran2026 d
